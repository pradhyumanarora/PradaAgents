# Example environment variables for the Agentic Team
# Copy this file to .env and fill in your values

# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o

# Azure DevOps Configuration (for PR Review Agent)
ADO_ORGANIZATION_URL=https://dev.azure.com/your-organization
ADO_PROJECT_NAME=your-project-name
ADO_REPOSITORY_NAME=your-repo-name

# Optional: Team Configuration
TEAM_MAX_ITERATIONS=25
ALLOW_REPEATED_SPEAKER=true
MODEL_TEMPERATURE=0.7
MODEL_MAX_TOKENS=4096
