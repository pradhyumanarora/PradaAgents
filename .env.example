# Example environment variables for the Agentic Team
# Copy this file to .env and fill in your values

# OpenAI Configuration (use EITHER plain OpenAI OR Azure OpenAI)
# --- Option A: Direct OpenAI ---
# OPENAI_API_KEY=sk-your-openai-api-key-here
# OPENAI_MODEL=gpt-4o

# --- Option B: Azure OpenAI (recommended) ---
AZURE_OPENAI_ENDPOINT=https://pradh-mmzb9jgb-eastus2.cognitiveservices.azure.com
AZURE_OPENAI_API_KEY=your-azure-openai-key-here
AZURE_OPENAI_API_VERSION=2024-12-01-preview
OPENAI_MODEL=gpt-5.3-chat

# Azure DevOps Configuration (for PR Review Agent)
ADO_ORGANIZATION_URL=https://dev.azure.com/your-organization
ADO_PROJECT_NAME=your-project-name
ADO_REPOSITORY_NAME=your-repo-name

# Optional: Team Configuration
TEAM_MAX_ITERATIONS=25
ALLOW_REPEATED_SPEAKER=true
MODEL_TEMPERATURE=0.7
MODEL_MAX_TOKENS=4096
